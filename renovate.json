{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "baseBranchPatterns": ["develop"],
  "timezone": "Asia/Tokyo",
  "schedule": ["before 10am on Monday"],
  "prConcurrentLimit": 10,
  "reviewers": ["necofuryai"],
  "labels": ["dependencies", "automated"],
  "semanticCommits": "enabled",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "dependencyDashboard": true,
  "platformAutomerge": true,
  "automergeStrategy": "squash",
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "postUpdateOptions": ["pnpmDedupe"],
  "vulnerabilityAlerts": { "enabled": true },
  "osvVulnerabilityAlerts": true,
  "packageRules": [
    {
      "description": "Automerge patch and minor updates for npm packages",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Major npm updates need dashboard approval to create the PR, then automerge once the gate passes",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true,
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Group Astro ecosystem packages together",
      "matchManagers": ["npm"],
      "matchPackageNames": ["astro", "@astrojs/*"],
      "groupName": "astro-ecosystem",
      "groupSlug": "astro-ecosystem"
    },
    {
      "description": "Group Tailwind ecosystem packages together",
      "matchManagers": ["npm"],
      "matchPackageNames": ["tailwindcss", "@tailwindcss/*", "daisyui"],
      "groupName": "tailwind-ecosystem",
      "groupSlug": "tailwind-ecosystem"
    },
    {
      "description": "Playwright: group updates; automerge when the gate (incl. VRT) passes, regenerate baselines only when VRT fails",
      "matchManagers": ["npm"],
      "matchPackageNames": ["@playwright/test", "playwright", "playwright-core", "playwright-chromium"],
      "groupName": "playwright",
      "groupSlug": "playwright",
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Use chore(deps-dev) scope for devDependencies",
      "matchDepTypes": ["devDependencies"],
      "semanticCommitScope": "deps-dev"
    },
    {
      "description": "GitHub Actions: separate labels, scope, grouping, and automerge",
      "matchManagers": ["github-actions"],
      "labels": ["dependencies", "github-actions", "automated"],
      "semanticCommitScope": "actions",
      "groupName": "github-actions-all",
      "groupSlug": "github-actions-all",
      "automerge": true,
      "automergeType": "pr",
      "matchUpdateTypes": ["patch", "minor", "digest"],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Automerge major GitHub Actions updates once the gate passes",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["major"],
      "automerge": true,
      "automergeType": "pr"
    }
  ]
}
